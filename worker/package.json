{
  "name": "@openclaw/crabbox-worker",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "wrangler deploy --dry-run --outdir dist",
    "check": "tsc --noEmit",
    "deploy": "wrangler deploy",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --config .oxlintrc.json .",
    "test": "vitest run"
  },
  "dependencies": {
    "aws4fetch": "^1.0.20",
    "fast-xml-parser": "^5.7.2",
    "mppx": "^0.6.13"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.10",
    "wrangler": "^4.87.0"
  }
}
